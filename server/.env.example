# 이메일 자동 발송 설정 (선택사항)
# 이 파일을 .env로 복사하고 값을 채우세요.
# 환경변수가 설정되어 있지 않으면 임시비번을 관리자가 수동 전달해야 합니다.

# Gmail 예시 (앱 비밀번호 필요: https://myaccount.google.com/apppasswords)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=app-password-16-chars
# SMTP_FROM=your-email@gmail.com

# 네이버 예시
# SMTP_HOST=smtp.naver.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-id@naver.com
# SMTP_PASS=your-password
# SMTP_FROM=your-id@naver.com

# 다음(카카오) 예시
# SMTP_HOST=smtp.daum.net
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-id@daum.net
# SMTP_PASS=your-password
# SMTP_FROM=your-id@daum.net

# 회사 자체 메일 서버
# SMTP_HOST=mail.company.kr
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@company.kr
# SMTP_PASS=...
# SMTP_FROM=noreply@company.kr
